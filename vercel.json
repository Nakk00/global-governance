{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": ".",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "framework": "django",
      "maxDuration": 60,
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/maintainer",
      "destination": "/index.html"
    }
  ]
}
