{
  "name": "global-governance",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "supabase:start": "supabase start --ignore-health-check",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:functions": "supabase functions serve --env-file .env.local --no-verify-jwt",
    "supabase:functions:chat": "supabase functions serve chat --env-file .env.local --no-verify-jwt",
    "supabase:dev": "pnpm supabase:start && pnpm supabase:functions",
    "backend:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py check --settings=config.settings.development",
    "backend:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py runserver 127.0.0.1:8000 --settings=config.settings.development",
    "backend:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m pytest -c backend/pyproject.toml backend/tests",
    "dev:backend-stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-stack.ps1",
    "chatbot:prepare-ingestion": "node --experimental-strip-types scripts/chatbot/prepare-ingestion.ts",
    "chatbot:validate-boundaries": "node --experimental-strip-types scripts/chatbot/validate-chatbot-boundaries.ts",
    "chatbot:validate-set": "node --experimental-strip-types scripts/chatbot/validate-chatbot-set.ts",
    "test:unit": "vitest run",
    "test:functions": "vitest run -c supabase/functions/vitest.config.ts",
    "test:e2e": "playwright test --grep-invert @chat-live",
    "test:e2e:all": "playwright test",
    "test:chat:live": "playwright test --grep @chat-live --workers 1",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@ladybugdb/core": "0.15.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.9.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.95.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
