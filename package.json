{
  "name": "global-governance",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "redis:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis.ps1 start",
    "redis:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis.ps1 stop",
    "redis:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis.ps1 status",
    "redis:insight:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis-insight.ps1 start",
    "redis:insight:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis-insight.ps1 stop",
    "redis:insight:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/redis-insight.ps1 status",
    "supabase:start": "supabase start --ignore-health-check",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:functions": "supabase functions serve --env-file .env.local --no-verify-jwt",
    "supabase:dev": "pnpm supabase:start && pnpm supabase:functions",
    "backend:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py check --settings=config.settings.development",
    "backend:migrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py migrate --settings=config.settings.development",
    "backend:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py runserver 127.0.0.1:8000 --settings=config.settings.development",
    "backend:ingest:approved": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 backend/manage.py ingest_approved_sources --settings=config.settings.development",
    "backend:lint": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m ruff check backend",
    "backend:format": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m ruff format backend",
    "backend:typecheck": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m mypy --config-file backend/pyproject.toml backend",
    "backend:security": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m pip_audit -r backend/requirements.txt",
    "backend:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m pytest -c backend/pyproject.toml backend/tests",
    "backend:test:coverage": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-python.ps1 -m pytest -c backend/pyproject.toml --cov=chatbot --cov=retrieval --cov=ingestion --cov=sources --cov=validation --cov-branch --cov-report=term-missing --cov-report=html:backend/htmlcov --cov-fail-under=80 backend/tests",
    "local:dev": "pnpm dev:backend-stack",
    "dev:backend-stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/backend-stack.ps1",
    "chatbot:prepare-ingestion": "node --experimental-strip-types scripts/chatbot/prepare-ingestion.ts",
    "chatbot:audit-prompts": "node --experimental-strip-types scripts/chatbot/audit-suggested-prompts.ts",
    "chatbot:validate-boundaries": "node --experimental-strip-types scripts/chatbot/validate-chatbot-boundaries.ts",
    "chatbot:validate-set": "node --experimental-strip-types scripts/chatbot/validate-chatbot-set.ts",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:functions": "vitest run -c supabase/functions/vitest.config.ts",
    "test:e2e": "playwright test --grep @smoke --grep-invert @chat-live",
    "test:e2e:mocked": "playwright test --grep-invert @chat-live",
    "test:e2e:journey": "playwright test --grep @journey --grep-invert @chat-live",
    "test:e2e:layout": "playwright test --grep @layout --grep-invert @chat-live",
    "test:e2e:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/playwright-chat-live.ps1 -All",
    "test:chat:live": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev/playwright-chat-live.ps1",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/inter": "^5.2.8",
    "@ladybugdb/core": "0.15.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.9.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.95.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
