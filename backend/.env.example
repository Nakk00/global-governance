# Django runtime. Keep this file server-only; do not expose these values to Vite.
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-with-local-development-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Local Supabase services used by the Django backend.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SUPABASE_ANON_KEY=replace-with-local-anon-key

# Optional local service dependencies for later protected chat stories.
REDIS_URL=redis://127.0.0.1:6379/0
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=
NVIDIA_MODEL=
