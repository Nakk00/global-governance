# Browser-safe values exposed by Vite. Prefix public frontend values with VITE_.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_CHAT_FUNCTION_URL=http://127.0.0.1:54321/functions/v1/chat

# Django backend values live in backend/.env and must not be imported from src/.
# Copy backend/.env.example to backend/.env for local backend development.
