+      ) : (
+        <DashboardView
+          dashboard={dashboardState.dashboard}
+          selectedSourceId={selectedSourceId}
+          detailState={detailState}
+          mutationState={mutationState}
+          onSelectSource={setSelectedSourceId}
+          onUploadSource={(payload) =>
