+type ProtectionRecord = {
+  submissions: number[]
+  consecutiveAbuseCount: number
+  cooldownUntil: number
+}
+
+export type ProtectionStore = Map<string, ProtectionRecord>
+
+export type ChatProtectionDecision =
+  | {
+      state: "allowed"
+    }
+  | {
+      state: "refused"
+      consecutiveAbuseCount: number
+    }
+  | {
+      state: "cooldown"
+      code: "rate_limited" | "abuse_cooldown"
+      retryAfterSeconds: number
+    }
+
+const windowMs = 60_000
+const maxSubmissionsPerWindow = 10
+const abuseThreshold = 3
+const abuseCooldownMs = 60_000
+const courseBoundaryKeywords = [
+  "global governance",
+  "governance",
+  "world government",
+  "un",
+  "united nations",
+  "security council",
+  "institution",
+  "institutions",
+  "charter",
+  "sovereignty",
+  "source",
+  "sources",
+  "citation",
+  "chapter",
+  "course",
+  "west philippine sea",
+  "wps",
+  "arbitral",
+  "ruling",
+  "maritime",
+]
+
+export const chatProtectionStore = createMemoryProtectionStore()
+
+export function createMemoryProtectionStore(): ProtectionStore {
+  return new Map<string, ProtectionRecord>()
+}
+
+export function resetProtectionStore(store: ProtectionStore): void {
+  store.clear()
+}
+
+export function resolveAnonymousSessionId(request: Request): string {
+  const explicitSession = request.headers.get("x-anonymous-session-id")?.trim()
+
+  if (explicitSession) {
+    return explicitSession.slice(0, 120)
+  }
+
+  const forwardedFor = request.headers.get("x-forwarded-for")?.trim()
+  const userAgent = request.headers.get("user-agent")?.trim()
+
+  return `${forwardedFor ?? "local"}:${userAgent ?? "unknown"}`
+}
+
+export function evaluateChatProtection({
+  sessionId,
+  question,
+  now = Date.now(),
+  store = chatProtectionStore,
+}: {
+  sessionId: string
+  question: string
+  now?: number
+  store?: ProtectionStore
+}): ChatProtectionDecision {
+  const record = getProtectionRecord(store, sessionId)
+
+  record.submissions = record.submissions.filter(
+    (submissionTime) => now - submissionTime < windowMs
+  )
+
+  if (record.cooldownUntil > now) {
+    return {
+      state: "cooldown",
+      code: "abuse_cooldown",
+      retryAfterSeconds: secondsUntil(record.cooldownUntil, now),
+    }
+  }
+
+  if (record.submissions.length >= maxSubmissionsPerWindow) {
+    const oldestSubmission = record.submissions[0]
+
+    return {
+      state: "cooldown",
+      code: "rate_limited",
+      retryAfterSeconds: secondsUntil(oldestSubmission + windowMs, now),
+    }
+  }
+
+  record.submissions.push(now)
+
+  if (!isCourseBoundaryQuestion(question)) {
+    record.consecutiveAbuseCount += 1
+
+    if (record.consecutiveAbuseCount >= abuseThreshold) {
+      record.cooldownUntil = now + abuseCooldownMs
+
+      return {
+        state: "cooldown",
+        code: "abuse_cooldown",
+        retryAfterSeconds: secondsUntil(record.cooldownUntil, now),
+      }
+    }
+
+    return {
+      state: "refused",
+      consecutiveAbuseCount: record.consecutiveAbuseCount,
+    }
+  }
+
+  record.consecutiveAbuseCount = 0
+
+  return {
+    state: "allowed",
+  }
+}
+
+function getProtectionRecord(
+  store: ProtectionStore,
+  sessionId: string
+): ProtectionRecord {
+  const existing = store.get(sessionId)
+
+  if (existing) {
+    return existing
+  }
+
+  const nextRecord = {
+    submissions: [],
+    consecutiveAbuseCount: 0,
+    cooldownUntil: 0,
+  }
+
+  store.set(sessionId, nextRecord)
+
+  return nextRecord
+}
+
+function secondsUntil(targetTime: number, now: number): number {
+  return Math.max(1, Math.ceil((targetTime - now) / 1_000))
+}
+
+function isCourseBoundaryQuestion(question: string): boolean {
+  const normalizedQuestion = question.toLowerCase()
+
+  return courseBoundaryKeywords.some((keyword) =>
+    normalizedQuestion.includes(keyword)
+  )
+}
